<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Responsive Image Gallery</title>

<style>
/* =========================
   GENERAL STYLES
========================= */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: Arial, sans-serif;
    background: #0a0000;
    padding: 20px;
}

/* =========================
   HEADING
========================= */
h1 {
    text-align: center;
    margin-bottom: 20px;
    color: #6e6161;
}

/* =========================
   FILTER BUTTONS
========================= */
.filters {
    text-align: center;
    margin-bottom: 20px;
}

.filters button {
    padding: 10px 18px;
    margin: 5px;
    border: none;
    border-radius: 5px;
    background: #333;
    color: white;
    cursor: pointer;
    transition: 0.3s;
}

.filters button:hover {
    background: #ff9800;
}

/* =========================
   GALLERY GRID
========================= */
.gallery {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 15px;
}

.gallery-item {
    overflow: hidden;
    border-radius: 10px;
    box-shadow: 0 4px 8px rgba(0,0,0,0.2);
    background: white;
}

.gallery-item img {
    width: 100%;
    height: 220px;
    object-fit: cover;
    cursor: pointer;
    transition: transform 0.4s ease, filter 0.4s ease;
}

/* Hover Effect */
.gallery-item img:hover {
    transform: scale(1.08);
    filter: brightness(80%);
}

/* =========================
   LIGHTBOX
========================= */
.lightbox {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.9);
    justify-content: center;
    align-items: center;
    z-index: 1000;
    flex-direction: column;
    padding: 20px;
}

.lightbox img {
    max-width: 90%;
    max-height: 80vh;
    border-radius: 10px;
    animation: fadeIn 0.4s ease;
}

@keyframes fadeIn {
    from { opacity: 0; transform: scale(0.95); }
    to   { opacity: 1; transform: scale(1); }
}

/* Close Button */
.close {
    position: absolute;
    top: 20px;
    right: 30px;
    font-size: 40px;
    color: white;
    cursor: pointer;
}

/* Navigation Buttons */
.nav-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(255,255,255,0.2);
    color: white;
    border: none;
    padding: 15px 20px;
    font-size: 24px;
    cursor: pointer;
    border-radius: 50%;
    transition: 0.3s;
}

.nav-btn:hover {
    background: rgba(255,255,255,0.4);
}

.prev {
    left: 20px;
}

.next {
    right: 20px;
}

/* =========================
   RESPONSIVE
========================= */
@media (max-width: 768px) {
    .gallery-item img {
        height: 180px;
    }

    .nav-btn {
        padding: 10px 14px;
        font-size: 20px;
    }

    .close {
        font-size: 32px;
        right: 20px;
    }
}

@media (max-width: 480px) {
    .gallery {
        grid-template-columns: 1fr;
    }

    .gallery-item img {
        height: 200px;
    }
}
</style>
</head>
<body>

<h1>Responsive Image Gallery</h1>

<!-- FILTER BUTTONS -->
